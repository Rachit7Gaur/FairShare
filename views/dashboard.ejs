<div class="container mt-5">
  <div class="profile-card p-4 mb-4">
    <h1 class="mb-4">Welcome, <%= user.username %>!</h1>
    <p class="text-muted">Your email: <%= user.email %></p>
  </div>

  <h2 class="mb-3 text-center">Your Groups</h2>
  <div class="row">
    <% if (userGroups && userGroups.length > 0) { %>
      <% userGroups.forEach(group => { %>
        <div class="col-md-4 mb-3">
          <div class="frosted-card">
            <div class="card-body">
              <h5 class="card-title"><%= group.name %></h5>
              <a href="/groups/<%= group._id %>" class="btn btn-gradient btn-sm">View Group</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="alert alert-info frosted-card">No groups yet. Create one below!</div>
    <% } %>
  </div>

  <div class="text-center mt-4">
    <a href="/groups/new" class="btn btn-gradient">Create New Group</a>
  </div>

  <div class="mt-4 text-center">
    <a href="/logout" class="btn btn-danger">Logout</a>
  </div>
</div>
