<div class="container mt-5">
  <h1 class="mb-4">Welcome, <%= user.username %>!</h1>
  <p class="text-muted">Your email: <%= user.email %></p>

  <!-- Groups Section -->
  <h2 class="mb-3">Your Groups</h2>
  <div class="row">
    <% if (userGroups && userGroups.length > 0) { %>
      <% userGroups.forEach(group => { %>
        <div class="col-md-4 mb-3">
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= group.name %></h5>
              <a href="/groups/<%= group._id %>" class="btn btn-outline-primary btn-sm">View Group</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="alert alert-info">No groups yet. Create one below!</div>
    <% } %>
  </div>

  <!-- Create Group Form -->
  <h2 class="mt-4 mb-3 text-center">Create a New Group</h2>
    <div class="row justify-content-center">
      <div class="col-md-6">
        <div class="card shadow-sm">
          <div class="card-body">
            <form action="/groups" method="POST">
              <!-- Group Name -->
              <div class="mb-3">
                <label for="groupName" class="form-label">Group Name</label>
                <input 
                  type="text" 
                  class="form-control" 
                  id="groupName" 
                  name="name" 
                  placeholder="Enter group name" 
                  required>
              </div>

              <!-- Submit Button -->
              <div class="d-grid">
                <button type="submit" class="btn btn-success">Create Group</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>


  <!-- Logout Button -->
  <div class="mt-4">
    <a href="/logout" class="btn btn-danger">Logout</a>
  </div>
</div>