<div class="container mt-5">

<div class="card shadow-sm mb-4">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <h2 class="card-title mb-0"><%= group.name %></h2>
      <p class="text-muted mb-0">
        Created by: <%= group.owner ? group.owner.username : "Unknown" %>
      </p>
    </div>
  
    <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#deleteGroupModal">
      <i class="bi bi-trash"></i> Delete Group
    </button>
  </div>
</div>

<div class="modal fade" id="deleteGroupModal" tabindex="-1" aria-labelledby="deleteGroupModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteGroupModalLabel">Confirm Deletion</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to delete the group "<%= group.name %>"?  
        This action cannot be undone.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form action="/groups/<%= group._id %>/delete?_method=DELETE" method="POST">
          <button type="submit" class="btn btn-danger">Yes, Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

  <h3 class="mb-3">Members</h3>
  <div class="row">
    <% group.members.forEach(member => { %>
      <div class="col-md-3 mb-3">
        <div class="card text-center shadow-sm">
          <div class="card-body">
            <h6 class="card-title"><%= member.username %></h6>
            <span class="badge bg-info">Member</span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>


  <div class="mt-3 mb-5">
    <a href="/groups/<%= group._id %>/add-member" class="btn btn-primary">
      ➕ Add Member
    </a>
  </div>

<h3 class="mt-4 mb-3">Expenses</h3>
<% if (expenses.length > 0) { %>
  <div class="table-responsive">
    <table class="table table-striped table-hover shadow-sm">
      <thead class="table-dark">
        <tr>
          <th>Description</th>
          <th>Amount</th>
          <th>Paid By</th>
          <th>Split Among</th>
          <th>Date</th>
          <th>Actions</th> 
        </tr>
      </thead>
      <tbody>
        <% expenses.forEach(expense => { %>
          <tr>
            <td><%= expense.description %></td>
            <td>₹<%= expense.amount %></td>
            <td>
              <span class="badge bg-info"><%= expense.paidBy.username %></span>
            </td>
            <td>
              <% expense.splitAmong.forEach(member => { %>
                <span class="badge bg-secondary"><%= member.username %></span>
              <% }) %>
            </td>
            <td><%= expense.date.toDateString() %></td>
            <td>
             
              <div class="d-flex justify-content-between align-items-center mb-2">
                
                <button class="btn btn-link text-danger p-0" 
                        data-bs-toggle="modal" 
                        data-bs-target="#deleteExpenseModal-<%= expense._id %>">
                  <i class="bi bi-trash"></i>
                  Delete
                </button>
              </div>

            
            <div class="modal fade" id="deleteExpenseModal-<%= expense._id %>" 
                tabindex="-1" 
                aria-labelledby="deleteExpenseModalLabel-<%= expense._id %>" 
                aria-hidden="true">
              <div class="modal-dialog">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="deleteExpenseModalLabel-<%= expense._id %>">
                      Confirm Expense Deletion
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <div class="modal-body">
                    Are you sure you want to delete "<%= expense.title %>" of ₹<%= expense.amount %>?  
                    This action cannot be undone.
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form action="/groups/<%= group._id %>/expenses/<%= expense._id %>/delete?_method=DELETE" method="POST">
                      <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    </form>
                  </div>
                </div>
              </div>
            </div>

            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="alert alert-info">No expenses added yet.</div>
<% } %>

  
  <div class="mt-3">
    <a href="/groups/<%= group._id %>/add-expense" class="btn btn-success">
      ➕ Add Expense
    </a>
  </div>


<h3 class="mt-4 mb-3">Balances</h3>
<table class="table table-bordered">
  <thead>
    <tr>
      <th>Member</th>
      <th>Balance</th>
    </tr>
  </thead>
  <tbody>
    <% group.members.forEach(member => { %>
      <tr>
        <td><%= member.username %></td>
        <td>
          <% if (balances[member._id] > 0) { %>
            <span class="text-success">Gets back ₹<%= balances[member._id].toFixed(2) %></span>
          <% } else if (balances[member._id] < 0) { %>
            <span class="text-danger">Owes ₹<%= Math.abs(balances[member._id]).toFixed(2) %></span>
          <% } else { %>
            <span class="text-muted">Settled</span>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<h3 class="mt-4 mb-3">Settlements</h3>
<% if (settlements.length > 0) { %>
  <ul class="list-group">
    <% settlements.forEach(s => { %>
      <li class="list-group-item">
        <strong><%= s.from %></strong> owes 
        <strong><%= s.to %></strong> ₹<%= s.amount.toFixed(2) %>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <div class="alert alert-info">All balances are settled!</div>
<% } %>



</div>