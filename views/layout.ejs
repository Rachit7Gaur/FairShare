<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>FairShare</title>
  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" 
    rel="stylesheet" 
    integrity="sha384-..." 
    crossorigin="anonymous">

  <style>
    .fade-out {
      opacity: 0;
      transition: opacity 1s ease-out;
    }
    html, body {
      height: 100%;
      margin: 0;
    }
    body {
      background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e') center/cover no-repeat fixed;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    main {
      flex: 1;
    }

    :root {
  --bs-primary: #0077ff;   /* Accent blue */
  --bs-secondary: #00c9a7; /* Teal accent */
  --bs-body-bg: #f0f4f8;   /* Soft neutral background */
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  background: rgba(255,255,255,0.3); /* light overlay */
  z-index: -1;
}


.login-card {
  backdrop-filter: blur(12px);
  background: rgba(255, 255, 255, 0.85);
  border-radius: 12px;
  padding: 2rem;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

.btn-gradient {
  background: linear-gradient(90deg, var(--bs-primary), var(--bs-secondary));
  border: none;
  color: #fff;
  transition: 0.3s;
}
.btn-gradient:hover {
  filter: brightness(1.1);
}

.btn-google {
  background: #db4437;
  color: #fff;
  border: none;
}
.btn-google:hover {
  background: #c23321;
}

.form-control:focus {
  border-color: var(--bs-primary);
  box-shadow: 0 0 0 0.2rem rgba(0,119,255,0.25);
}

.navbar {
  backdrop-filter: blur(12px);
  background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e') center/cover no-repeat;
  border-bottom: 3px solid transparent;
  border-image: linear-gradient(to right, var(--bs-primary), var(--bs-secondary));
  border-image-slice: 1;
  position: relative;
   z-index: 1050;
}

.navbar::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5); /* stronger overlay for contrast */
}

.navbar-brand,
.nav-link {
  color: #fff !important; /* force white text */
  position: relative;
  z-index: 1; /* ensures text sits above overlay */
}

.nav-link:hover {
  color: var(--bs-secondary) !important; /* teal accent on hover */
}

.hero-section {
  position: relative;
  background: url('https://images.unsplash.com/photo-1507525428034-b723cf961d3e') center/cover no-repeat fixed;
  padding: 5rem 2rem;
  border-radius: 12px;
}
.hero-section::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.4); /* overlay for readability */
  border-radius: 12px;
}
.hero-card {
  position: relative;
  z-index: 1;
  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.85);
  border-radius: 12px;
  padding: 2rem;
  max-width: 800px;
  margin: auto;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}
.hero-card h1, .hero-card p {
  text-shadow: 0 2px 6px rgba(0,0,0,0.5);
}

.card {
  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.85);
  border-radius: 12px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  transition: transform 0.3s;
}
.card:hover {
  transform: translateY(-5px);
}

.footer {
  backdrop-filter: blur(12px);
  background: linear-gradient(90deg, #0077ff, #00c9a7);
  color: #fff;
}

.profile-card {
  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.85);
  border-radius: 12px;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
}

.frosted-card {
  backdrop-filter: blur(12px);
  background: rgba(255,255,255,0.85);
  border-radius: 12px;
  padding: 1.5rem;
  box-shadow: 0 8px 20px rgba(0,0,0,0.1);
  transition: transform 0.3s;
}
.frosted-card:hover {
  transform: translateY(-5px);
}

.btn-gradient {
  background: linear-gradient(90deg, var(--bs-primary), var(--bs-secondary));
  border: none;
  color: #fff !important;
  border-radius: 25px;
  padding: 6px 16px;
  transition: 0.3s;
}
.btn-gradient:hover {
  filter: brightness(1.1);
  box-shadow: 0 0 12px rgba(0,119,255,0.5);
}
.dropdown-menu {
  z-index: 2000; /* ensures dropdown is above hero card */
}
</style>
</head>
<body>
  <%- include('partials/navbar') %>   

  <main>
    <div class="container mt-3">
      <% if (success && success.length) { %>
        <% success.forEach(msg => { %>
          <div class="alert alert-success alert-dismissible fade show auto-dismiss" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% }) %>
      <% } %>

      <% if (error && error.length) { %>
        <% error.forEach(msg => { %>
          <div class="alert alert-danger alert-dismissible fade show auto-dismiss" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% }) %>
      <% } %>

      <% if (info && info.length) { %>
        <% info.forEach(msg => { %>
          <div class="alert alert-info alert-dismissible fade show auto-dismiss" role="alert">
            <%= msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% }) %>
      <% } %>
    </div>

    <%- body %>
  </main>

  <%- include('partials/footer') %>

  <script 
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
    integrity="sha384-..." 
    crossorigin="anonymous">
  </script>
  <script>
    setTimeout(() => {
      document.querySelectorAll('.auto-dismiss').forEach(alert => {
        alert.classList.add('fade-out');
        alert.addEventListener('transitionend', () => {
          const bsAlert = new bootstrap.Alert(alert);
          bsAlert.close();
        }, { once: true });
      });
    }, 3000);
  </script>
</body>
</html>